# Copy to .env.local for local dev. Never commit real secrets.

# --- Database ---
# Local: matches docker-compose.yml. Prod: Coolify internal Postgres hostname.
DATABASE_URL=postgres://dev:dev@localhost:5432/apikeys

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Better Auth (human/session auth) ---
BETTER_AUTH_SECRET= # 32+ random bytes: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# --- API key crypto (machine/key auth) ---
API_KEY_PEPPER= # 32+ random bytes: openssl rand -hex 32

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
LOG_LEVEL=info
