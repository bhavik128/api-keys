{
  "name": "api-keys",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "auth:generate": "bunx @better-auth/cli@latest generate --config src/server/auth.ts --output src/db/auth-schema.ts -y",
    "build": "next build",
    "check": "ultracite check",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d postgres redis",
    "dev": "next dev",
    "fix": "ultracite fix",
    "format": "biome format --write",
    "lint": "biome check",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "4.13.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@tailwindcss/postcss": "4.3.2",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "0.31.10",
    "lefthook": "2.1.10",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "ultracite": "7.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
